# Schwab API Credentials
SCHWAB_APP_KEY=your_app_key
SCHWAB_APP_SECRET=your_app_secret
SCHWAB_CALLBACK_URL=https://127.0.0.1:8182

# Token Storage
TOKEN_PATH=./tokens/schwab_tokens.db

# Default Settings
DEFAULT_SYMBOL=SPX
GEX_LEVEL_MAX_DTE=45

# Cache Settings
CACHE_DIRECTORY=./cache
# Quote cache TTL in seconds. Schwab allows 120 req/min — lower = fresher data.
QUOTE_CACHE_TTL=5
